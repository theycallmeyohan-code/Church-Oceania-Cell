{
  "name": "church-oceania-cell",
  "pages_build_output_dir": "./public",
  "compatibility_date": "2026-07-04",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "church-oceania-cell-db",
      "database_id": "b51e4001-db25-4428-bb3c-a42930afa54a",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "church-oceania-member-photos"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production"
  }
}
